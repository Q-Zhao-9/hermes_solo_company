SITELET_AUTH_SECRET=replace-with-at-least-32-random-characters
SITELET_DATA_DIR=.sitelet
SITELET_GENERATED_DIR=.sitelet/generated

# Optional public origin used in generated preview links when behind a proxy.
SITELET_PUBLIC_URL=https://sitelet.example.com

# Optional cookie override. Leave unset in HTTPS deployments. Use false for local
# production-mode HTTP previews such as http://localhost:3020.
SITELET_COOKIE_SECURE=false

# Optional local-only escape hatch. Keep false in shared/cloud deployments.
SITELET_ALLOW_ANONYMOUS_UPLOADS=false
